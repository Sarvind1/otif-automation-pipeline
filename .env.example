# SharePoint Configuration
SHAREPOINT_TENANT_ID=your_sharepoint_tenant_id_here
SHAREPOINT_CLIENT_ID=your_sharepoint_client_id_here
SHAREPOINT_CLIENT_SECRET=your_sharepoint_client_secret_here

# Redshift Configuration
REDSHIFT_HOST=your_redshift_host_here
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=your_database_name_here
REDSHIFT_USER=your_username_here
REDSHIFT_PASSWORD=your_password_here

# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_REGION=us-east-1

# Application Settings
LOG_LEVEL=INFO
OUTPUT_FOLDER=./outputs
